<Window x:Class="TsrApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:TsrApp.Converters"
        mc:Ignorable="d"
        Title="Распознавание дорожных знаков"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:HexStringToColorConverter x:Key="HexToColor"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="240"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Top">
                <Button Content="Загрузить изображение"
                        Padding="14,8"
                        FontSize="14"
                        Command="{Binding LoadImageCommand}"/>
                <Button Content="Очистить историю"
                        Padding="14,8"
                        FontSize="14"
                        Margin="8,0,0,0"
                        Command="{Binding ClearHistoryCommand}"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="16,0,0,0"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <Border Background="{Binding ConfidenceColor, Converter={StaticResource HexToColor}}"
                        CornerRadius="4"
                        Padding="12,8">
                    <TextBlock Text="{Binding ResultText}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               TextWrapping="Wrap"/>
                </Border>
                <TextBlock Text="{Binding Top3Text}"
                           Margin="2,8,0,0"
                           FontSize="12"
                           Foreground="#444"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="#DDD"
                BorderThickness="1"
                Background="#F5F5F5"
                Margin="0,0,0,12">
            <Image Source="{Binding ImagePath}"
                   Stretch="Uniform"
                   Margin="8"/>
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding History}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Время"        Binding="{Binding Timestamp}"          Width="200"/>
                <DataGridTextColumn Header="Файл"          Binding="{Binding ImagePath}"          Width="*"/>
                <DataGridTextColumn Header="ID"            Binding="{Binding PredictedClassId}"   Width="50"/>
                <DataGridTextColumn Header="Класс"         Binding="{Binding PredictedClassName}" Width="300"/>
                <DataGridTextColumn Header="Уверенность"   Binding="{Binding Confidence, StringFormat={}{0:P1}}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
