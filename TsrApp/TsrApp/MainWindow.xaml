<Window x:Class="TsrApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:TsrApp.Converters"
        mc:Ignorable="d"
        Title="Распознавание дорожных знаков"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:HexStringToColorConverter x:Key="HexToColor"/>
        <conv:ConfidenceToColorConverter x:Key="ConfToColor"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

    <TabControl Grid.Row="0" SelectedIndex="{Binding SelectedModeIndex}">

        <!-- ===== Режим 1: Классификатор (без изменений поведения) ===== -->
        <TabItem Header="Классификатор">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button Content="Загрузить изображение"
                                Padding="14,8"
                                FontSize="14"
                                Command="{Binding LoadImageCommand}"/>
                        <Button Content="Очистить историю"
                                Padding="14,8"
                                FontSize="14"
                                Margin="8,0,0,0"
                                Command="{Binding ClearHistoryCommand}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                        <Border Background="{Binding ConfidenceColor, Converter={StaticResource HexToColor}}"
                                CornerRadius="4"
                                Padding="12,8">
                            <TextBlock Text="{Binding ResultText}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       TextWrapping="Wrap"/>
                        </Border>
                        <TextBlock Text="{Binding Top3Text}"
                                   Margin="2,8,0,0"
                                   FontSize="12"
                                   Foreground="#444"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        BorderBrush="#DDD"
                        BorderThickness="1"
                        Background="#F5F5F5"
                        Margin="0,0,0,12">
                    <Image Source="{Binding ImagePath}"
                           Stretch="Uniform"
                           Margin="8"/>
                </Border>
            </Grid>
        </TabItem>

        <!-- ===== Режим 2: Детектор (рамки поверх изображения) ===== -->
        <TabItem Header="Детектор">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="Загрузить изображение"
                            Padding="14,8"
                            FontSize="14"
                            Command="{Binding DetectImageCommand}"/>
                </StackPanel>

                <Border Grid.Row="1"
                        BorderBrush="#DDD"
                        BorderThickness="1"
                        Background="#F5F5F5">
                    <Grid>
                        <!-- Изображение в натуральных пикселях + Canvas-оверлей рамок,
                             всё внутри Viewbox: рамки заданы в пиксельных координатах
                             исходного кадра и масштабируются вместе с картинкой. -->
                        <Viewbox Stretch="Uniform" Margin="8">
                            <Grid Width="{Binding DetectorImageWidth}"
                                  Height="{Binding DetectorImageHeight}">
                                <Image Source="{Binding DetectorImageSource}" Stretch="Fill"/>
                                <ItemsControl ItemsSource="{Binding Detections}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Box.X}"/>
                                            <Setter Property="Canvas.Top" Value="{Binding Box.Y}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Rectangle Width="{Binding Box.Width}"
                                                           Height="{Binding Box.Height}"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Top"
                                                           Stroke="{Binding Confidence, Converter={StaticResource ConfToColor}}"
                                                           StrokeThickness="3"/>
                                                <Border Background="{Binding Confidence, Converter={StaticResource ConfToColor}}"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Margin="0,-18,0,0"
                                                        Padding="3,1">
                                                    <TextBlock Foreground="White" FontSize="12">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} {1:P0}">
                                                                <Binding Path="ClassName"/>
                                                                <Binding Path="Confidence"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Viewbox>

                        <TextBlock Text="Знаков не найдено"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   Foreground="#999"
                                   Visibility="{Binding NoSignsFound, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>

        <!-- ===== Режим 3: Видео (проигрывание mp4; рамки — на шаге инференса) ===== -->
        <TabItem Header="Видео">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="Открыть видео"
                            Padding="14,8"
                            FontSize="14"
                            Command="{Binding Video.OpenVideoCommand}"/>
                    <Button Content="▶ Play"
                            Padding="14,8"
                            FontSize="14"
                            Margin="8,0,0,0"
                            Command="{Binding Video.PlayCommand}"/>
                    <Button Content="⏸ Pause"
                            Padding="14,8"
                            FontSize="14"
                            Margin="8,0,0,0"
                            Command="{Binding Video.PauseCommand}"/>
                    <Button Content="⏹ Stop"
                            Padding="14,8"
                            FontSize="14"
                            Margin="8,0,0,0"
                            Command="{Binding Video.StopCommand}"/>
                    <CheckBox Content="Распознавание"
                              VerticalAlignment="Center"
                              Margin="16,0,0,0"
                              FontSize="14"
                              IsChecked="{Binding Video.IsInferenceEnabled}"/>
                    <Button Content="Экспорт с разметкой"
                            Padding="14,8"
                            FontSize="14"
                            Margin="16,0,0,0"
                            Command="{Binding Video.ExportWithOverlayCommand}"/>
                    <Button Content="Отмена экспорта"
                            Padding="14,8"
                            FontSize="14"
                            Margin="8,0,0,0"
                            Command="{Binding Video.CancelExportCommand}"/>
                </StackPanel>

                <Border Grid.Row="1"
                        BorderBrush="#DDD"
                        BorderThickness="1"
                        Background="#F5F5F5">
                    <Grid>
                        <!-- Та же структура, что в «Детекторе»: кадр в натуральных
                             пикселях + Canvas-оверлей внутри Viewbox. Оверлей пока
                             пуст — рамки добавим на шаге инференса. -->
                        <Viewbox Stretch="Uniform" Margin="8">
                            <Grid Width="{Binding Video.FrameWidth}"
                                  Height="{Binding Video.FrameHeight}">
                                <Image Source="{Binding Video.FrameSource}" Stretch="Fill"/>
                                <ItemsControl ItemsSource="{Binding Video.VideoTracks}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                            <Setter Property="Visibility"
                                                    Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Rectangle Width="{Binding Width}"
                                                           Height="{Binding Height}"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Top"
                                                           Stroke="{Binding Confidence, Converter={StaticResource ConfToColor}}"
                                                           StrokeThickness="3"/>
                                                <Border Background="{Binding Confidence, Converter={StaticResource ConfToColor}}"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Margin="0,-18,0,0"
                                                        Padding="3,1">
                                                    <TextBlock Foreground="White" FontSize="12">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} {1:P0} #{2}">
                                                                <Binding Path="ClassName"/>
                                                                <Binding Path="Confidence"/>
                                                                <Binding Path="Id"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Viewbox>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="2"
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#444"
                           Text="{Binding Video.StatusText}"/>
            </Grid>
        </TabItem>

    </TabControl>

        <!-- ===== Общая панель истории/лога: видна во всех режимах ===== -->
        <DataGrid Grid.Row="1"
                  Margin="0,12,0,0"
                  ItemsSource="{Binding History}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Время"        Binding="{Binding Timestamp}"          Width="200"/>
                <DataGridTextColumn Header="Режим"        Binding="{Binding Mode}"               Width="90"/>
                <DataGridTextColumn Header="Файл"          Binding="{Binding ImagePath}"          Width="*"/>
                <DataGridTextColumn Header="ID"            Binding="{Binding PredictedClassId}"   Width="50"/>
                <DataGridTextColumn Header="Класс"         Binding="{Binding PredictedClassName}" Width="300"/>
                <DataGridTextColumn Header="Уверенность"   Binding="{Binding Confidence, StringFormat={}{0:P1}}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
